# ROSA frontend env vars
# Copy to `.env` for local builds, or set these in your hosting dashboard
# (Railway / Vercel / etc.) for production.
#
# IMPORTANT: Vite bakes env vars at BUILD time. Whenever you change one of
# these, you must trigger a fresh build — restarting the server is NOT enough.

# Public URL of the api-server. No trailing slash.
# Example (Railway):  https://rosa-api-production.up.railway.app
# Example (custom):   https://api.rosainclusive.lifestyle
# Leave UNSET for Replit dev — the artifact proxy handles routing automatically.
VITE_API_URL=
